# Copy this file to `.env` and fill in the values.
# Never commit .env — it's in .gitignore.

# ─── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ctauser:ctapassword@localhost:5432/cta_track?schema=public"

# ─── Redis ─────────────────────────────────────────────────────────────
# In production (Railway, Render, Fly) prefer REDIS_URL. For local docker-compose
# the HOST/PORT form is fine.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:6379

# ─── Auth ──────────────────────────────────────────────────────────────
# Use a long random string in production. Rotate if leaked.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ─── CTA API keys ──────────────────────────────────────────────────────
# Register at https://www.transitchicago.com/developers/
CTA_TRAIN_API_KEY=
CTA_BUS_API_KEY=

# ─── Google Gemini ─────────────────────────────────────────────────────
# Free tier at https://ai.google.dev
GOOGLE_GEMINI_API_KEY=

# ─── Telegram Bot ──────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram. The webhook secret is any random
# string — Telegram includes it in the webhook header, and it's also the
# admin secret for POST /api/telegram/setup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# ─── Schedule timezone ─────────────────────────────────────────────────
# IANA zone that schedule HH:mm values are interpreted in.
SCHEDULE_TIMEZONE=America/Chicago

# ─── Cache ─────────────────────────────────────────────────────────────
CACHE_TTL=60

# ─── Email (optional secondary channel) ────────────────────────────────
# Leaving these blank disables email delivery — Telegram is the primary channel.
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=

# ─── Sentry (optional error reporting) ─────────────────────────────────
# Create a Node project at https://sentry.io, paste the DSN here.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
