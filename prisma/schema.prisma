// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String       @id @default(cuid())
  email                    String       @unique
  name                     String?
  password                 String
  telegramChatId           String?      @unique
  telegramLinkToken        String?      @unique
  emailNotifications       Boolean      @default(false)
  // Global mute: while in the future, all scheduled deliveries are skipped.
  notificationsPausedUntil DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  favorites                Favorite[]
  schedules                Schedule[]
  notificationLogs         NotificationLog[]

  @@map("users")
}

model Favorite {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Route information
  routeType   RouteType  // TRAIN or BUS
  routeId     String     // e.g., "Blue", "Red" for trains, "157" for buses

  // For trains
  stationId   String?    // CTA station ID (boarding station)
  direction   String?    // e.g., "5" for service toward O'Hare

  // For buses
  stopId      String?    // CTA bus stop ID (boarding stop)

  // Trip endpoints (for both trains and buses)
  boardingStopId     String?  // Where you GET ON (stop ID for bus, station ID for train)
  boardingStopName   String?  // Display name for boarding location
  alightingStopId    String?  // Where you GET OFF (stop ID for bus, station ID for train)
  alightingStopName  String?  // Display name for alighting location

  // Display name
  name        String     // User-friendly name: "Blue Line to UIC-Halsted"

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  schedules   Schedule[]

  @@map("favorites")
}

model Schedule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteId  String
  favorite    Favorite  @relation(fields: [favoriteId], references: [id], onDelete: Cascade)

  // Scheduling details
  time        String    // Target arrival time in HH:mm (America/Chicago)
  daysOfWeek  Int[]     // Array of days: 0=Sunday, 1=Monday, etc.
  enabled     Boolean   @default(true)

  // How many minutes BEFORE `time` we should send the ping.
  // e.g. time="08:30", leadMinutes=15 → fires at 08:15 Chicago.
  leadMinutes Int       @default(0)

  // Delivery channel selection. AUTO prefers Telegram when linked,
  // falls back to email; BOTH sends via every configured channel.
  channel     Channel   @default(AUTO)

  // Set by the scheduler each time a job is enqueued for this schedule;
  // used to dedupe within the same minute window.
  lastTriggeredAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  notificationLogs NotificationLog[]

  @@map("schedules")
}

enum RouteType {
  TRAIN
  BUS
}

enum Channel {
  AUTO
  EMAIL
  TELEGRAM
  BOTH
}

// Append-only record of delivery attempts. Makes "why didn't my email arrive?"
// answerable without tailing server logs.
model NotificationLog {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleId String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  channel    String    // "EMAIL" | "TELEGRAM"
  status     String    // "SENT" | "FAILED" | "SKIPPED"
  detail     String?   // Error message, skip reason, or provider message id
  kind       String    @default("SCHEDULED") // "SCHEDULED" | "TEST"

  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("notification_logs")
}
